@{ ViewData["Title"] = "Đăng nhập"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="mb-0">Đăng Nhập Hệ Thống</h3>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
{
    <div class="alert alert-danger" style="color: red; font-weight: bold;">
        @ViewBag.Error
    </div>
}
                    <form asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tài khoản (Email):</label>
                            <input type="text" name="username" class="form-control" placeholder="Nhập email..." required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu:</label>
                            <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu..." required />
                        </div>
                        <button type="submit" class="btn btn-success w-100 fw-bold fs-5 mt-2">Đăng Nhập</button>
                    </form>
                    <div class="text-center mt-3">
                        <p>Chưa có tài khoản? <a asp-controller="Account" asp-action="Register" class="text-success fw-bold">Đăng ký ngay</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>