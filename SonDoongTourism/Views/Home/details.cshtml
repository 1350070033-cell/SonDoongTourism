@model SonDoongTourism.Models.Tour

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <div class="row bg-white p-4 rounded-4 shadow-sm">
        <div class="col-md-6 mb-4 mb-md-0">
            <img src="@Model.ImageUrl" class="img-fluid rounded-4 shadow" alt="@Model.Name" style="width: 100%; height: 400px; object-fit: cover;" />
        </div>
        
        <div class="col-md-6 d-flex flex-column justify-content-center px-md-4">
            <h1 class="text-success fw-bold display-5 mb-3">@Model.Name</h1>
            
            <div class="d-flex align-items-center mb-4">
                <span class="badge bg-primary fs-6 me-3"><i class="bi bi-clock"></i> @Model.DurationDays Ngày</span>
                <h3 class="text-danger fw-bold mb-0">@Model.Price.ToString("N0") VNĐ</h3>
            </div>
            
            <hr />
            
            <div class="mt-3 flex-grow-1">
                <h4 class="fw-bold mb-3">Khám phá hành trình</h4>
                <p class="text-secondary" style="line-height: 1.8; font-size: 1.1rem; text-align: justify;">
                    @Model.Description 
                </p>
            </div>
            
            <div class="mt-4 d-flex gap-3 pt-3 border-top">
                <a href="/Home/Book/@Model.Id" class="btn btn-success btn-lg fw-bold flex-grow-1 shadow-sm">🚀 Đặt Tour Ngay</a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">🔙 Trở về</a>
            </div>
        </div>
    </div>
</div>