@{
    ViewData["Title"] = "Chính sách & Cam kết";
}

<div class="container mt-5 p-5 bg-white shadow rounded-4">
    <h1 class="text-success border-bottom pb-3">@ViewData["Title"]</h1>
    
    <div class="row mt-4">
        <div class="col-md-6">
            <h3><i class="bi bi-shield-check text-primary"></i> Bảo mật thông tin</h3>
            <p>Chúng tôi cam kết bảo mật tuyệt đối thông tin cá nhân của khách hàng khi đặt tour tại hệ thống.</p>
        </div>
        <div class="col-md-6">
            <h3><i class="bi bi-heart-pulse text-danger"></i> An toàn là trên hết</h3>
            <p>Mọi hành trình đều được trang bị thiết bị bảo hộ đạt tiêu chuẩn quốc tế và hướng dẫn viên chuyên nghiệp.</p>
        </div>
    </div>
    
    <div class="alert alert-info mt-4">
        <strong>Lưu ý:</strong> Mọi thay đổi về lịch trình do thời tiết sẽ được thông báo trước ít nhất 24 giờ.
    </div>
</div>