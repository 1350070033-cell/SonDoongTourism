@model SonDoongTourism.Models.Booking
@{ 
    ViewData["Title"] = "Đặt Tour"; 
    // Biến phụ để tránh lỗi Null
    var price = ViewBag.TourPrice != null ? (int)ViewBag.TourPrice : 0;
}

<div class="container mt-5">
    <div class="card shadow border-0 mx-auto" style="max-width: 600px;">
        <div class="card-header bg-success text-white text-center">
            <h3 class="mb-0">Xác Nhận Đặt Tour</h3>
        </div>
        <div class="card-body p-4">
            <h5 class="text-danger fw-bold text-center mb-4">
                @ViewBag.TourName - Giá: @price.ToString("N0") VNĐ
            </h5>
            
            <form asp-action="Book" method="post">
                <input type="hidden" asp-for="TourId" />
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và Tên của bạn:</label>
                    <input asp-for="CustomerName" class="form-control" placeholder="Nhập tên..." required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email liên hệ:</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email..." required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Số điện thoại liên hệ:</label>
                    <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại..." required />
                </div>

                <button type="submit" class="btn btn-success w-100 fw-bold fs-5 mt-3">Thanh Toán & Đặt Chỗ</button>
            </form>
        </div>
    </div>
</div>